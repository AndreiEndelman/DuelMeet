# Copy this file to .env and fill in your values

# MongoDB connection string (get from MongoDB Atlas or local instance)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tcg-duel-meet?retryWrites=true&w=majority

# JWT secret — use a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret

# Token lifetime (e.g. 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# Port the Express server listens on
PORT=5000

# Comma-separated list of allowed frontend origins (no trailing slashes)
# Development defaults (localhost:8100 = Ionic dev, localhost:4200 = ng serve)
ALLOWED_ORIGINS=http://localhost:8100,http://localhost:4200
